{
  "models": {
    "providers": {
      "openai": {
        "baseUrl": "http://host.docker.internal:8317/v1",
        "apiKey": "__OPENAI_API_KEY__",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "gpt-5.4",
            "api": "openai-completions"
          },
          {
            "id": "gpt-5-codex-mini",
            "name": "gpt-5-codex-mini",
            "api": "openai-completions"
          }
        ],
        "api": "openai-completions"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4"
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "__OPENCLAW_TOKEN__"
    }
  }
}
